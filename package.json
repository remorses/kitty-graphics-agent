{
  "name": "kitty-graphics-agent",
  "version": "0.0.2",
  "description": "Intercept Kitty Graphics Protocol images from CLI output and inject them into LLM context. A spec and OpenCode plugin for agent-CLI image passing.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist *.tsbuildinfo && tsc",
    "prepublishOnly": "pnpm build",
    "test": "vitest"
  },
  "keywords": [
    "kitty",
    "graphics",
    "protocol",
    "terminal",
    "images",
    "llm",
    "agent",
    "opencode",
    "cli",
    "apc",
    "escape-sequence"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/remorses/kitty-graphics-agent.git"
  },
  "homepage": "https://github.com/remorses/kitty-graphics-agent",
  "bugs": {
    "url": "https://github.com/remorses/kitty-graphics-agent/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.2.27",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
